{
  "name": "tailwind-sprint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "ios:setup": "npm run build && npx cap sync ios",
    "ios:bundle": "bash scripts/build-ios-bundle.sh"
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.4",
    "@upstash/redis": "^1.35.4",
    "mapbox-gl": "^3.3.0",
    "next": "^16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-map-gl": "^7.1.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
